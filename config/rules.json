{
  "ports": {
    "allowed": ["22", "80", "443"],
    "dangerous": {
      "21": "FTP (insecure)",
      "23": "Telnet (insecure)",
      "3306": "MySQL exposed",
      "6379": "Redis exposed",
      "27017": "MongoDB exposed"
    }
  },

  "ssh": {
    "permit_root_login": "no",
    "password_authentication": "no"
  },

  "kernel": {
    "kernel.randomize_va_space": "2",
    "kernel.kptr_restrict": "2"
  },

  "network": {
  "net.ipv4.ip_forward": {
    "value": "0",
    "severity": "HIGH"
  },
  "net.ipv4.conf.all.accept_redirects": {
    "value": "0",
    "severity": "HIGH"
  },
  "net.ipv4.conf.all.send_redirects": {
    "value": "0",
    "severity": "HIGH"
  },
  "net.ipv4.conf.all.accept_source_route": {
    "value": "0",
    "severity": "MEDIUM"
  },
  "net.ipv4.conf.all.log_martians": {
    "value": "1",
    "severity": "MEDIUM"
  },
  "net.ipv4.icmp_echo_ignore_broadcasts": {
    "value": "1",
    "severity": "LOW"
  }
  },

  "services": {
  "dangerous": ["telnet", "rsh", "rexec"],
  "unnecessary": ["avahi-daemon", "cups", "bluetooth", "rpcbind"]
  },

  "cron": {
  "allowed_permissions": ["600", "640", "700", "750"],
  "require_cron_allow": true,
  "check_world_writable": true
  },

  "filesystem": {
    "shadow_permission": "640",
    "passwd_permission": "644"
  },

  "auth": {
  "pass_max_days": 365,
  "pass_min_days": 1,
  "pass_warn_age": 7,
  "hashing": "SHA512"
  }

}